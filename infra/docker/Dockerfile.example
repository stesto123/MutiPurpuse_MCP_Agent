# syntax=docker/dockerfile:1
#
# Example local image for AI Scout. This is intentionally conservative:
# - no secrets are copied into the image;
# - the app runs as an unprivileged user;
# - local config and runtime data are mounted at container runtime.

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN useradd --system --create-home --uid 10001 ai_scout \
    && mkdir -p /data /app \
    && chown -R ai_scout:ai_scout /data /app

COPY --chown=ai_scout:ai_scout . /app

RUN python -m pip install --upgrade pip \
    && if [ -f pyproject.toml ]; then python -m pip install -e .; else echo "No pyproject.toml found; image will use the runtime entrypoint template only."; fi

USER ai_scout

ENTRYPOINT ["sh", "/app/infra/scripts/run-ai-scout.example.sh"]
