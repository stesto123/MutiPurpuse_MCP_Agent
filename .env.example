# Public-safe environment template for AI Scout.
#
# Copy to .env for local Docker Compose use:
#   cp .env.example .env
#
# Replace /Users/YOUR_USER with your local paths. Do not put API keys, OAuth
# refresh tokens, or other secret values in .env. Use secret files, OS secret
# stores, or MCP-server-specific private config instead.

AI_SCOUT_MODE=dry_run
AI_SCOUT_LOG_LEVEL=INFO
AI_SCOUT_COMMAND=ai-scout

# Host paths used by Docker Compose.
AI_SCOUT_HOST_CONFIG_DIR=/Users/YOUR_USER/.config/ai-scout
AI_SCOUT_HOST_DATA_DIR=/Users/YOUR_USER/.local/share/ai-scout
AI_SCOUT_HOST_SECRETS_DIR=/Users/YOUR_USER/.config/ai-scout/secrets

# Container path used by docker-compose.example.yaml.
AI_SCOUT_CONTAINER_CONFIG_DIR=/host-config

# Local CLI paths for non-container runs.
AI_SCOUT_CONFIG_DIR=/Users/YOUR_USER/.config/ai-scout
AI_SCOUT_DATA_DIR=/Users/YOUR_USER/.local/share/ai-scout

# Autonomous mode is intentionally gated. Leave this commented for dry runs.
# AI_SCOUT_AUTONOMOUS_CONFIRM=I_UNDERSTAND_AUTONOMOUS_SIDE_EFFECTS

# Optional placeholder referenced by config/profiles/local.example.yaml.
# Put real calendar identifiers only in private local config when possible.
# AI_SCOUT_CALENDAR_ID=CALENDAR_ID_PLACEHOLDER
